# ─── ROS2 colcon build outputs ───────────────────────────────
build/
install/
log/

# ─── PlatformIO (firmware/stm32 มี .gitignore ของตัวเองอยู่แล้ว)
firmware/stm32/.pio/
firmware/stm32/.vscode/c_cpp_properties.json

# ─── Python cache ─────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ─── ROS2 Python package cache ────────────────────────────────
src/**/__pycache__/
src/**/*.pyc

# ─── VSCode workspace (ถ้าไม่อยากแชร์ settings) ──────────────
# .vscode/           ← comment ออกถ้าอยากเก็บ settings ไว้

# ─── OS junk ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Editor swap / temp ───────────────────────────────────────
*.swp
*.swo
*~
